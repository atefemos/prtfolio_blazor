@using PersonalPortfolio.Components
@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">Hello, I'm Atefe Moslemi</h1>
                <h3 class="h4 mb-4 text-light">Full-Stack ASP.NET Core Developer</h3>
                <p class="lead mb-4">
                    I create modern, responsive web applications using ASP.NET Core, Blazor, 
                    and the latest web technologies. Passionate about clean code and user experience.
                </p>
                <div class="d-flex gap-3">
                    <a href="/Home/Projects" class="btn btn-light btn-lg">
                        <i class="fas fa-code me-2"></i>View My Work
                    </a>
                    <a href="#contact" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-envelope me-2"></i>Get In Touch
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <img src="/images/portfolio.png" alt="Atefe Moslemi" class="img-fluid rounded-circle" style="max-width: 300px;">
            </div>
        </div>
    </div>
</section>
<!-- Contact Section -->
<section id="contact" class="section-padding">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="text-center mb-5">
                    <h2 class="display-5 fw-bold">Let's Work Together</h2>
                    <p class="lead">Ready to bring your project to life?</p>
                </div>
                <component type="typeof(ContactForm)" render-mode="ServerPrerendered" />
            </div>
        </div>
    </div>
</section>
