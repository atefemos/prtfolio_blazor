@using PersonalPortfolio.Models

<div class="col-md-6 col-lg-4 mb-4">
    <div class="card project-card h-100">
        @if (!string.IsNullOrEmpty(Project.ImageUrl))
        {
            <img src="@Project.ImageUrl" class="card-img-top" alt="@Project.Title" style="height: 200px; object-fit: cover;">
        }
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">@Project.Title</h5>
            <p class="card-text">@Project.Description</p>
            <div class="mb-3">
                @foreach (var tech in Project.TechStack.Split(','))
                {
                    <span class="badge bg-secondary me-1">@tech.Trim()</span>
                }
            </div>
            <div class="mt-auto">
                @if (!string.IsNullOrEmpty(Project.LiveUrl))
                {
                    <a href="@Project.LiveUrl" class="btn btn-primary btn-sm me-2" target="_blank">
                        <i class="fas fa-external-link-alt"></i> Live Demo
                    </a>
                }
                <!-- Add GitHub link button here -->
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Project Project { get; set; } = new();
}